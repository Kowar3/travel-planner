              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Test Trip\",\n  \"description\": \"Test opis putovanja\",\n  \"startDate\": \"2026-08-01\",\n  \"endDate\": \"2026-08-10\",\n  \"totalBudget\": 1000,\n  \"startCity\": \"Kragujevac\",\n  \"startLat\": 43.9993,\n  \"startLng\": 20.9244,\n  \"endCity\": \"Bec\",\n  \"endLat\": 48.2082,\n  \"endLng\": 16.3738\n}"
            },
            "url": "{{BASE_URL}}/trips"
          }
        },
        {
          "name": "Get All Trips",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has trips array', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('trips');",
                  "  pm.expect(body.trips).to.be.an('array');",
                  "});",
                  "pm.test('Pagination fields present', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('totalPages');",
                  "  pm.expect(body).to.have.property('currentPage');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": "{{BASE_URL}}/trips?page=1&limit=6"
          }
        },
        {
          "name": "Get Trips - Filter Upcoming",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.trips).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": "{{BASE_URL}}/trips?status=upcoming"
          }
        },
        {
          "name": "Get Trip By ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
