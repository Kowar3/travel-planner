{
  "info": {
    "name": "Travel Planner API",
    "_postman_id": "travel-planner-collection",
    "description": "Kompletna kolekcija za testiranje Travel Planner REST API-ja.\n\nRedosled pokretanja:\n1. Auth - Register\n2. Auth - Login (automatski setuje TOKEN varijablu)\n3. Ostali zahtevi koriste {{TOKEN}} i {{TRIP_ID}}, {{DEST_ID}} itd.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:5000/api" },
    { "key": "TOKEN", "value": "" },
    { "key": "REGISTERED_EMAIL", "value": "" },
    { "key": "TRIP_ID", "value": "" },
    { "key": "DEST_ID", "value": "" },
    { "key": "ACTIVITY_ID", "value": "" },
    { "key": "EXPENSE_ID", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "",
                  "if (pm.response.code === 201) {",
                  "    if (body.token) {",
                  "        pm.collectionVariables.set('TOKEN', body.token);",
                  "    }",
                  "    if (body.user && body.user.email) {",
                  "        pm.collectionVariables.set('REGISTERED_EMAIL', body.user.email);",
                  "    }",
                  "}",
                  "",
                  "pm.test('Status 201 Created', () => {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response contains Auth Data', () => {",
                  "    pm.expect(body).to.have.property('token');",
                  "    pm.expect(body).to.have.property('user');",
                  "});",
                  "",
                  "pm.test('User details are correct', () => {",
                  "    pm.expect(body.user).to.have.property('email');",
                  "    pm.expect(body.user).to.have.property('firstName');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"email\": \"testuser{{$randomInt}}@test.com\",\n  \"password\": \"Test123!\"\n}"
            },
            "url": "{{BASE_URL}}/auth/register"
          }
        },
        {
          "name": "Register - Validation Error (weak password)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 for weak password', () => pm.response.to.have.status(400));",
                  "pm.test('Error message present', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('message');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"email\": \"weak@test.com\",\n  \"password\": \"123\"\n}"
            },
            "url": "{{BASE_URL}}/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Token saved', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('token');",
                  "  pm.collectionVariables.set('TOKEN', body.token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{REGISTERED_EMAIL}}\",\n  \"password\": \"Test123!\"\n}"
            },
            "url": "{{BASE_URL}}/auth/login"
          }
        },
        {
          "name": "Login - Wrong Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 for wrong password', () => pm.response.to.have.status(400));",
                  "pm.test('Error message returned', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message).to.include('Invalid');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{REGISTERED_EMAIL}}\",\n  \"password\": \"WrongPassword!\"\n}"
            },
            "url": "{{BASE_URL}}/auth/login"
          }
        },
        {
          "name": "Protected Route - No Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401 without token', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/trips"
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Get Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Profile has required fields', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('email');",
                  "  pm.expect(body).to.have.property('firstName');",
                  "  pm.expect(body).to.have.property('lastName');",
                  "  pm.expect(body).to.not.have.property('password');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": "{{BASE_URL}}/users/profile"
          }
        },
        {
          "name": "Update Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Name updated', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.firstName).to.equal('Updated');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Updated\",\n  \"lastName\": \"User\"\n}"
            },
            "url": "{{BASE_URL}}/users/profile"
          }
        }
      ]
    },
    {
      "name": "Trips",
      "item": [
        {
          "name": "Create Trip",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
